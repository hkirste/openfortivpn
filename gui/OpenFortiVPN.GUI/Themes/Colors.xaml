<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    OpenFortiVPN Color System
    Inspired by Windows 11 Fluent Design with a professional VPN-security aesthetic.
    Uses a blue-teal accent palette that communicates trust and security.
    -->

    <!-- === Primary Brand Colors === -->
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="AccentLightColor">#47A7F5</Color>
    <Color x:Key="AccentDarkColor">#005A9E</Color>
    <Color x:Key="AccentSubtleColor">#E8F4FD</Color>

    <!-- === Semantic Colors === -->
    <Color x:Key="SuccessColor">#0F7B0F</Color>
    <Color x:Key="SuccessLightColor">#DFF6DD</Color>
    <Color x:Key="WarningColor">#9D5D00</Color>
    <Color x:Key="WarningLightColor">#FFF4CE</Color>
    <Color x:Key="ErrorColor">#C42B1C</Color>
    <Color x:Key="ErrorLightColor">#FDE7E9</Color>
    <Color x:Key="InfoColor">#0078D4</Color>

    <!-- === Connection State Colors === -->
    <Color x:Key="ConnectedColor">#0F7B0F</Color>
    <Color x:Key="ConnectingColor">#0078D4</Color>
    <Color x:Key="DisconnectedColor">#8A8886</Color>
    <Color x:Key="ErrorStateColor">#C42B1C</Color>
    <Color x:Key="ReconnectingColor">#CA5010</Color>

    <!-- === Light Theme Surface Colors === -->
    <Color x:Key="BackgroundColor">#F3F3F3</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceVariantColor">#F9F9F9</Color>
    <Color x:Key="SidebarColor">#F0F0F0</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="CardHoverColor">#F5F5F5</Color>
    <Color x:Key="DividerColor">#E5E5E5</Color>
    <Color x:Key="BorderColor">#D1D1D1</Color>
    <Color x:Key="BorderSubtleColor">#E5E5E5</Color>

    <!-- === Text Colors === -->
    <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#616161</Color>
    <Color x:Key="TextTertiaryColor">#8A8886</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>
    <Color x:Key="TextDisabledColor">#A19F9D</Color>

    <!-- === Brushes (used in XAML bindings) === -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="ErrorLightBrush" Color="{StaticResource ErrorLightColor}" />

    <SolidColorBrush x:Key="ConnectedBrush" Color="{StaticResource ConnectedColor}" />
    <SolidColorBrush x:Key="ConnectingBrush" Color="{StaticResource ConnectingColor}" />
    <SolidColorBrush x:Key="DisconnectedBrush" Color="{StaticResource DisconnectedColor}" />
    <SolidColorBrush x:Key="ErrorStateBrush" Color="{StaticResource ErrorStateColor}" />
    <SolidColorBrush x:Key="ReconnectingBrush" Color="{StaticResource ReconnectingColor}" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHoverColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />

</ResourceDictionary>
