<Window x:Class="OpenFortiVPN.GUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OpenFortiVPN.GUI.ViewModels"
        xmlns:views="clr-namespace:OpenFortiVPN.GUI.Views"
        xmlns:converters="clr-namespace:OpenFortiVPN.GUI.Converters"
        xmlns:controls="clr-namespace:OpenFortiVPN.GUI.Controls"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="920" Height="640"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:ConnectionStateToBrushConverter x:Key="StateToBrush" />

        <!-- View-to-DataTemplate mapping (ViewModel-first navigation) -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileListViewModel}">
            <views:ProfileListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileEditorViewModel}">
            <views:ProfileEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogViewerViewModel}">
            <views:LogViewerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220" />
            <!-- Content area -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ====== LEFT SIDEBAR ====== -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Header -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <!-- App Name -->
                    <TextBlock Text="OpenFortiVPN"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Fortinet SSL VPN Client"
                               Style="{StaticResource CaptionStyle}" />
                </StackPanel>

                <!-- Navigation Items -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 Content="Dashboard"
                                 IsChecked="{Binding SelectedNavItem, Converter={StaticResource NavItemConverter}, ConverterParameter=Dashboard, Mode=OneWay}"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Dashboard" />

                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 Content="Profiles"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Profiles" />

                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 Content="Log Viewer"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Logs" />

                    <Separator Style="{StaticResource DividerStyle}"
                               Margin="8,12" />

                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 Content="Settings"
                                 Command="{Binding NavigateToCommand}"
                                 CommandParameter="Settings" />
                </StackPanel>

                <!-- Bottom Status Panel -->
                <Border DockPanel.Dock="Bottom"
                        Margin="12,12"
                        Padding="12,10"
                        CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Status dot -->
                        <Ellipse Grid.Column="0"
                                 Width="10" Height="10"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding ConnectionState,
                                        Converter={StaticResource StateToBrush}}" />

                        <!-- Status text -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusText}"
                                   Style="{StaticResource CaptionStyle}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <!-- Spacer -->
                <Border />
            </DockPanel>
        </Border>

        <!-- ====== MAIN CONTENT AREA ====== -->
        <Border Grid.Column="1" Padding="0">
            <ContentControl Content="{Binding CurrentView}" />
        </Border>
    </Grid>
</Window>
