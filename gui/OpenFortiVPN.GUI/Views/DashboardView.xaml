<UserControl x:Class="OpenFortiVPN.GUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OpenFortiVPN.GUI.ViewModels"
             xmlns:converters="clr-namespace:OpenFortiVPN.GUI.Converters"
             xmlns:controls="clr-namespace:OpenFortiVPN.GUI.Controls"
             xmlns:helpers="clr-namespace:OpenFortiVPN.GUI.Helpers"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:ConnectionStateToBrushConverter x:Key="StateToBrush" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28">
        <StackPanel MaxWidth="700">

            <!-- Page Title -->
            <TextBlock Text="Dashboard" Style="{StaticResource TitleLargeStyle}"
                       Margin="0,0,0,24" />

            <!-- ============ CONNECTION STATUS CARD ============ -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Status Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                Margin="0,0,0,16">
                        <controls:StatusIndicator State="{Binding ConnectionState}"
                                                  Margin="0,0,16,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource TitleStyle}" />
                            <TextBlock Text="{Binding ConnectionDuration}"
                                       Style="{StaticResource MonoStyle}"
                                       Visibility="{Binding IsConnected,
                                                    Converter={StaticResource BoolToVis}}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Connection Details (visible when connected) -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding IsConnected,
                                       Converter={StaticResource BoolToVis}}"
                          Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Your IP" Style="{StaticResource CaptionStyle}" />
                            <TextBlock Text="{Binding AssignedIp}"
                                       Style="{StaticResource BodyStrongStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Gateway" Style="{StaticResource CaptionStyle}" />
                            <TextBlock Text="{Binding GatewayIp}"
                                       Style="{StaticResource BodyStrongStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1">
                            <TextBlock Text="DNS Servers" Style="{StaticResource CaptionStyle}" />
                            <TextBlock Text="{Binding DnsInfo}"
                                       Style="{StaticResource BodyStrongStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="1">
                            <TextBlock Text="Interface" Style="{StaticResource CaptionStyle}" />
                            <TextBlock Text="{Binding TunnelInterface}"
                                       Style="{StaticResource BodyStrongStyle}" />
                        </StackPanel>
                    </Grid>

                    <!-- Connect/Disconnect Button -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="Disconnect"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding DisconnectCommand}"
                                Visibility="{Binding IsConnected,
                                             Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ ERROR CARD ============ -->
            <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource ErrorLightBrush}"
                    BorderBrush="{StaticResource ErrorBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding ErrorMessage}"
                               Style="{StaticResource BodyStrongStyle}"
                               Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />

                    <TextBlock Grid.Row="1"
                               Text="{Binding ErrorSuggestion}"
                               Style="{StaticResource BodyStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="Trust Certificate &amp; Retry"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding TrustCertificateAndRetryCommand}"
                                Visibility="{Binding IsCertError,
                                             Converter={StaticResource BoolToVis}}"
                                Margin="0,0,8,0" />

                        <Button Content="Dismiss"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DismissErrorCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ OTP INPUT CARD ============ -->
            <Border Visibility="{Binding IsOtpRequired, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Two-Factor Authentication"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,0,0,8" />
                    <TextBlock Text="Enter the one-time password from your authenticator app."
                               Style="{StaticResource BodyStyle}"
                               Margin="0,0,0,12" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding OtpToken, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 FontSize="18"
                                 MaxLength="8"
                                 Margin="0,0,8,0" />

                        <Button Grid.Column="1"
                                Content="Submit"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SubmitOtpCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ QUICK CONNECT CARD ============ -->
            <Border Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis},
                                         ConverterParameter=Invert}"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Quick Connect"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,0,0,16" />

                    <!-- Profile Selection -->
                    <TextBlock Text="Profile" Style="{StaticResource CaptionStyle}"
                               Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource ModernComboBoxStyle}"
                              Margin="0,0,0,12" />

                    <!-- Password -->
                    <TextBlock Text="Password" Style="{StaticResource CaptionStyle}"
                               Margin="0,0,0,4" />
                    <PasswordBox Style="{StaticResource ModernPasswordBoxStyle}"
                                 helpers:PasswordBoxHelper.BoundPassword="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" />

                    <!-- Save password checkbox -->
                    <CheckBox Content="Save password"
                              IsChecked="{Binding SavePassword}"
                              Style="{StaticResource ModernCheckBoxStyle}"
                              Margin="0,0,0,16" />

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Connect"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ConnectCommand}"
                                IsEnabled="{Binding HasProfiles}"
                                Margin="0,0,8,0" />

                        <Button Content="New Profile"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CreateNewProfileCommand}" />
                    </StackPanel>

                    <!-- No profiles hint -->
                    <TextBlock Visibility="{Binding HasProfiles,
                                            Converter={StaticResource BoolToVis},
                                            ConverterParameter=Invert}"
                               Text="Create a profile to get started."
                               Style="{StaticResource CaptionStyle}"
                               Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <!-- ============ RECENT LOGS CARD ============ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Recent Activity"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,0,0,12" />

                    <ItemsControl ItemsSource="{Binding RecentLogs}"
                                  MaxHeight="200">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                               Style="{StaticResource MonoStyle}"
                                               Foreground="{StaticResource TextTertiaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Message}"
                                               Style="{StaticResource MonoStyle}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
