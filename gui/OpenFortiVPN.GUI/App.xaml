<Application x:Class="OpenFortiVPN.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:OpenFortiVPN.GUI.Helpers"
             xmlns:converters="clr-namespace:OpenFortiVPN.GUI.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Typography.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:ConnectionStateToBrushConverter x:Key="StateToBrush" />
            <converters:LogSeverityToBrushConverter x:Key="SeverityToBrush" />
            <converters:EnumToDisplayConverter x:Key="EnumDisplay" />
            <helpers:NavItemConverter x:Key="NavItemConverter" />
        </ResourceDictionary>
    </Application.Resources>

</Application>
